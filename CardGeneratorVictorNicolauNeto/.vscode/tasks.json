{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "gradle: build",
            "type": "shell",
            "command": ".\\gradlew.bat",
            "args": ["build"],
            "group": "build",
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "gradle: bootRun",
            "type": "shell",
            "command": ".\\gradlew.bat",
            "args": ["bootRun"],
            "group": "build",
            "options": {
                "cwd": "${workspaceFolder}"
            }
        }
    ]
}